# AWS credentials (required for /prices?provider=aws)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-west-2

# GCP API key (required for GCP pricing)
# Get one at: console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Then enable "Cloud Billing API" in APIs & Services → Library
GCP_API_KEY=your_gcp_api_key_here
